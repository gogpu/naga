// language: metal1.0
#include <metal_stdlib>
#include <simd/simd.h>

using metal::uint;
struct DefaultConstructible {
    template<typename T>
    operator T() && {
        return T {};
    }
};

struct FragmentOutput {
    metal::float4 color;
    metal::float4 normal;
};

struct vs_mainInput {
};
struct vs_mainOutput {
    metal::float4 member [[position]];
};
vertex vs_mainOutput vs_main(
  uint vi [[vertex_id]]
) {
    return vs_mainOutput { metal::float4(0.0, 0.0, 0.0, 1.0) };
}


struct fs_mainInput {
};
struct fs_mainOutput {
    metal::float4 color [[color(0)]];
    metal::float4 normal [[color(1)]];
};
fragment fs_mainOutput fs_main(
  metal::float4 frag_coord [[position]]
) {
    FragmentOutput out = {};
    out.color = metal::float4(1.0, 0.0, 0.0, 1.0);
    out.normal = metal::float4(0.0, 0.0, 1.0, 1.0);
    FragmentOutput _e14 = out;
    const auto _tmp = _e14;
    return fs_mainOutput { _tmp.color, _tmp.normal };
}
