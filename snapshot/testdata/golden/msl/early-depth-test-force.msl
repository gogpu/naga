// language: metal1.0
#include <metal_stdlib>
#include <simd/simd.h>

using metal::uint;
struct DefaultConstructible {
    template<typename T>
    operator T() && {
        return T {};
    }
};


struct main_Output {
    metal::float4 member [[color(0)]];
};
fragment main_Output main_(
) {
    return main_Output { metal::float4(0.4, 0.3, 0.2, 0.1) };
}
