 metal::uint3 ts_main(
  threadgroup float& workgroupData
) {
    workgroupData = 1.0;
    taskPayload.colorMask = metal::float4(1.0, 1.0, 0.0, 1.0);
    taskPayload.visible = true;
    return metal::uint3(1u, 1u, 1u);
